{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/maps-api/:path*", "destination": "https://maps.googleapis.com/maps/api/:path*" },
    { "source": "/routes-api/:path*", "destination": "https://routes.googleapis.com/:path*" },
    { "source": "/api/:path*", "destination": "https://gassync-backend.onrender.com/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
